# AI API Configuration
AI_API_KEY=your-api-key-here
AI_API_URL=
AI_MODEL=
AI_PROVIDER=gpustack

# Provider-specific URLs (optional)
# GPUStack: http://gpustack.example.com/v1
# HuggingFace: https://router.huggingface.co/v1
GPUSTACK_API_URL=
HUGGINGFACE_API_URL=https://router.huggingface.co/v1
HUGGINGFACE_TOKEN=your-huggingface-token-here

# Model Settings (optional, defaults shown)
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_TOP_P=1.0
AI_FREQUENCY_PENALTY=0.0
AI_PRESENCE_PENALTY=0.0
# AI_STOP=seq1,seq2

# Docker Configuration
DOCKER_FRONTEND_PORT=5173
DOCKER_BACKEND_PORT=8080
